{
    "version": 2,
    "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend",
    "outputDirectory": "frontend/dist",
    "installCommand": "npm install",
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/server.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/backend/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/index.html"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}