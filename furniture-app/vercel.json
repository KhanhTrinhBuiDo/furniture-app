{
    "version": 2,
    "buildCommand": "npm install --prefix frontend && npx --prefix frontend vite build",
    "outputDirectory": "frontend/dist",
    "installCommand": "npm install",
    "functions": {
        "backend/server-vercel.js": {
            "includeFiles": "backend/**"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/server-vercel.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "/backend/server-vercel.js"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/index.html"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}